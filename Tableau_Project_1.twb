            <column caption='YoY Fatal Casualties' datatype='real' default-format='*▲0.00%;▼0.00%' name='[YoY Casualties (copy)_6351648931782667]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='([Calculation_6351648930705416]-[CY Fatal Casualties (copy)_6351648931528713])/[CY Fatal Casualties (copy)_6351648931528713]' />
